APP_NAME=Fast Video Whisper
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO
LOG_DIR=./log_files
LOG_FILE_PREFIX=app
LOG_BACKUP_COUNT=7
LOG_ENCODING=utf-8
DATABASE_URL=sqlite:///./app.db
TEMP_DIR=./temp_files
MAX_FILE_SIZE=2147483648
AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_ISSUER=fast-video-whisper
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_ALLOW_PUBLIC_REGISTER=false
AUTH_REQUIRE_CAPTCHA_FOR_LOGIN=true
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_BLOCK_SECONDS=900
AUTH_COOKIE_ACCESS_NAME=auth_access_token
AUTH_COOKIE_REFRESH_NAME=auth_refresh_token
AUTH_COOKIE_CSRF_NAME=auth_csrf_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_INITIAL_ADMIN_USERNAME=admin
AUTH_INITIAL_ADMIN_EMAIL=admin@example.com
AUTH_INITIAL_ADMIN_PASSWORD=ChangeMe123!
AUTH_INITIAL_ADMIN_DISPLAY_NAME=Super Admin
